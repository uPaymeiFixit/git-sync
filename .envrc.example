# git-sync configuration. Copy this file to .envrc and edit the values to match
# your setup. If you use direnv, `direnv allow` once in this directory and the
# vars below will load automatically whenever you cd in.
#
# If you don't use direnv, you can `source` this file from your shell, or set
# these vars in your shell rc (~/.zshrc, ~/.bashrc, ~/.config/fish/config.fish).

# REQUIRED. Where mirrored repos will be cloned to. Two subdirectories are
# created under here: Bitbucket/ and Gitlab/.
export GIT_SYNC_ROOT="$HOME/git/synced"

# REQUIRED for Bitbucket. The workspace slug — the part after bitbucket.org/
# in your repo URLs. Omit to skip Bitbucket entirely.
export GIT_SYNC_BITBUCKET_WORKSPACE=your-workspace-slug

# REQUIRED for GitLab. The hostname of your GitLab instance. Omit to skip
# GitLab entirely. Must match a hostname you've authenticated `glab` against
# (run `glab auth login --hostname <host>` once).
export GITLAB_HOST=gitlab.example.com

# REQUIRED for GitHub. The organization name to mirror. Omit to skip
# GitHub entirely.
export GIT_SYNC_GITHUB_ORG=your-github-org

# OPTIONAL. Comma-separated list of repos or path prefixes to skip.
# Case-insensitive prefix match. Trailing slashes are optional.
# Examples:
#   GIT_SYNC_SKIP="legacy-monorepo"                 # skips one repo by name
#   GIT_SYNC_SKIP="some-group/archive/"             # skips a whole subtree
#   GIT_SYNC_SKIP="legacy, some-group/archive"      # multiple entries
# export GIT_SYNC_SKIP=""

# OPTIONAL. Bitbucket credentials via env vars instead of ~/.netrc. The app
# password needs the read:repository:bitbucket scope. Create one at:
# https://bitbucket.org/account/settings/app-passwords/
# export GIT_SYNC_BITBUCKET_USER=your-bitbucket-username
# export GIT_SYNC_BITBUCKET_APP_PASSWORD=your-app-password

# OPTIONAL. GitHub credentials via env var instead of ~/.netrc. A classic
# PAT needs the 'repo' scope to access private repos; a fine-grained PAT
# needs 'Contents: Read' + 'Metadata: Read' on the target org.
# Create one at: https://github.com/settings/tokens
# export GIT_SYNC_GITHUB_TOKEN=your-personal-access-token

# OPTIONAL. Number of repos to sync in parallel. Default: 8.
# export GIT_SYNC_PARALLEL=8

# OPTIONAL. Max seconds for any single git clone or fetch. Default 1800
# (30 minutes), which fits first-time clones of multi-GB repos with server-
# side pack-building bottlenecks. Bump higher if you have repos that
# legitimately need more time.
# export GIT_SYNC_TIMEOUT=1800

# OPTIONAL. Clone/fetch depth — how many commits of history to pull per branch.
# Lower values save disk and bandwidth; higher values give more history. Set to
# 0 for full history (no --depth flag). Default: 100.
# Note: switching from a shallow value to 0 won't retroactively unshallow
# already-cloned repos. To unshallow an existing repo run:
#   git -C <repo> fetch --unshallow
# export GIT_SYNC_DEPTH=100

